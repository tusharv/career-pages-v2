# Copy to `.env` and fill in values.

# Supabase (required for /api/companies and company pages)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: use only locally or in CI to run `npm run seed:companies` or `npm run upload:logos`. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Company logos are served from the public bucket `company-logos` when NEXT_PUBLIC_SUPABASE_URL is set (run `npm run upload:logos` after applying storage migration).

# Postmark (report flow)
POSTMARK_API_KEY=

# Comma-separated company name fragments for the easter egg
NEXT_PUBLIC_EASTER_EGG_COMPANIES=company1,company2,company3

# Admin (optional UI hints only; real access is admin_allowlist in Supabase + RLS)
# ADMIN_EMAILS=tusharvaghela@gmail.com

# Supabase Auth: enable Google provider and add redirect URLs in dashboard:
# - http://localhost:3000/auth/callback
# - https://<your-production-domain>/auth/callback
